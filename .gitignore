# ────────────────────────────────────────────────────────────
# Docker
# ────────────────────────────────────────────────────────────
.env
# Trailing-slash patterns ignore directories only — drop the slash so
# the same patterns also catch symlinks (used when the bind-mount
# target is relocated to an external SSD via
# docker/relocate_workspace_to_ssd.sh).
docker/workspace
docker/huggingface
docker/zenoh_cache

# Per-backend runtime workspaces — model checkpoints / HF cache
# downloaded at inference time. Bind-mounted into the policy
# container at /workspace.
cyclo_brain/policy/lerobot/workspace/
cyclo_brain/policy/groot/workspace/
cyclo_brain/policy/lerobot/checkpoints/
cyclo_brain/policy/groot/checkpoints/

