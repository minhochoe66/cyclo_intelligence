#!/command/with-contenv sh
# cyclo_intelligence service finish — delegate to the shared finish script.

set -e

SERVICE_NAME="cyclo_intelligence"
COMMON_SCRIPT="/usr/local/lib/s6-services/ros2_service_finish.sh"

if [ -f "${COMMON_SCRIPT}" ]; then
    exec /command/with-contenv env SERVICE_NAME="${SERVICE_NAME}" \
        sh "${COMMON_SCRIPT}" "$@"
else
    echo "Error: Common script not found at ${COMMON_SCRIPT}" >&2
    exit 1
fi
