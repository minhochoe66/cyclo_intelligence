#!/command/with-contenv bash
# nginx service — serves the React UI on ${CYCLO_UI_PORT:-7080} and reverse-proxies
# /api/ → supervisor_api + /data-api/ → video_file_server.
# (orchestrator/ui/nginx.conf, copied to /etc/nginx/conf.d/default.conf
# at image build time).
#
# 's6-overlay v3' does NOT auto-detect nginx as a managed service, so
# this longrun is what actually keeps nginx alive. The Dockerfile
# (docker/Dockerfile.{arm64,amd64}) prepares /run/nginx.pid with the
# right ownership so master can run as the configured user.

set -e

port_or_default() {
    case "${1:-}" in
        ''|*[!0-9]*) printf '%s\n' "$2" ;;
        *) printf '%s\n' "$1" ;;
    esac
}

UI_PORT="$(port_or_default "${CYCLO_UI_PORT:-}" 7080)"
ROSBRIDGE_PORT="$(port_or_default "${CYCLO_ROSBRIDGE_PORT:-}" 7090)"
VIDEO_SERVER_PORT="$(port_or_default "${CYCLO_VIDEO_SERVER_PORT:-}" 7082)"
WEB_VIDEO_SERVER_PORT="$(port_or_default "${CYCLO_WEB_VIDEO_SERVER_PORT:-}" 7085)"
SUPERVISOR_API_PORT="$(port_or_default "${CYCLO_SUPERVISOR_API_PORT:-}" 7100)"

sed -i -E "s/listen[[:space:]]+[0-9]+;/listen ${UI_PORT};/" \
    /etc/nginx/conf.d/default.conf
sed -i -E "/location \\/api\\//,/}/ s#proxy_pass http://127\\.0\\.0\\.1:[0-9]+/#proxy_pass http://127.0.0.1:${SUPERVISOR_API_PORT}/#" \
    /etc/nginx/conf.d/default.conf
sed -i -E "/location = \/api\/navigation\/topics\/ws/,/}/ s#proxy_pass http://127\.0\.0\.1:[0-9]+/navigation/topics/ws;#proxy_pass http://127.0.0.1:${SUPERVISOR_API_PORT}/navigation/topics/ws;#" \
    /etc/nginx/conf.d/default.conf
sed -i -E "/location \\/data-api\\//,/}/ s#proxy_pass http://127\\.0\\.0\\.1:[0-9]+/#proxy_pass http://127.0.0.1:${VIDEO_SERVER_PORT}/#" \
    /etc/nginx/conf.d/default.conf

cat > /usr/share/nginx/html/cyclo-config.js <<EOF
window.__CYCLO_CONFIG__ = Object.freeze({
  uiPort: ${UI_PORT},
  rosbridgePort: ${ROSBRIDGE_PORT},
  videoServerPort: ${VIDEO_SERVER_PORT},
  webVideoServerPort: ${WEB_VIDEO_SERVER_PORT},
  supervisorApiPort: ${SUPERVISOR_API_PORT},
});
EOF

echo "[nginx] serving UI on port ${UI_PORT}"
echo "[nginx] runtime ports: rosbridge=${ROSBRIDGE_PORT} video=${VIDEO_SERVER_PORT} web_video=${WEB_VIDEO_SERVER_PORT} supervisor_api=${SUPERVISOR_API_PORT}"

exec nginx -g "daemon off;"
