#!/command/with-contenv bash
# Zenoh router used by rmw_zenoh_cpp and the policy-container SDK bridge.

set -eo pipefail

source /opt/ros/jazzy/setup.bash

HOST="${ZENOH_ROUTER_IP:-127.0.0.1}"
PORT="${ZENOH_ROUTER_PORT:-7447}"

router_is_reachable() {
    python3 - "$HOST" "$PORT" <<'PY'
import socket
import sys

host = sys.argv[1]
port = int(sys.argv[2])
with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
    sock.settimeout(0.5)
    sys.exit(0 if sock.connect_ex((host, port)) == 0 else 1)
PY
}

while true; do
    if router_is_reachable; then
        echo "[zenoh_router] existing router reachable at ${HOST}:${PORT}"
        sleep 5
        continue
    fi

    echo "[zenoh_router] starting rmw_zenohd on ${HOST}:${PORT}"
    ros2 run rmw_zenoh_cpp rmw_zenohd || true
    echo "[zenoh_router] rmw_zenohd exited; retrying"
    sleep 1
done
