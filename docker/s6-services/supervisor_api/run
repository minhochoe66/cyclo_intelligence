#!/command/with-contenv bash
# supervisor_api — FastAPI control plane (PLAN §4.7).
# Listens on ${CYCLO_SUPERVISOR_API_HOST}:${CYCLO_SUPERVISOR_API_PORT}
# (defaults 127.0.0.1:8100); nginx reverse-proxies /api/ to it.

set -e

export PYTHONUNBUFFERED=1
export PYTHONPATH=/opt/supervisor_api:${PYTHONPATH}

HOST="${CYCLO_SUPERVISOR_API_HOST:-127.0.0.1}"
PORT="${CYCLO_SUPERVISOR_API_PORT:-8100}"

echo "[supervisor_api] starting uvicorn on ${HOST}:${PORT} ..."

exec uvicorn supervisor_api.app:app \
    --app-dir /opt \
    --host "${HOST}" \
    --port "${PORT}" \
    --log-level info
