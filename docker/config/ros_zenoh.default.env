# Cyclo ROS/Zenoh default runtime env.
# Shared default. Running containers read the generated workspace copy:
#   docker/workspace/config/ros_zenoh.env
#
# For robot-specific changes, edit the workspace copy.
# Usually only ROS_DOMAIN_ID and ZENOH_ROUTER_IP need to change.

export ROS_DOMAIN_ID=30
export RMW_IMPLEMENTATION=rmw_zenoh_cpp

# Local Zenoh daemon: 127.0.0.1
# Remote Zenoh daemon example: 192.168.60.139
export ZENOH_ROUTER_IP=127.0.0.1
export ZENOH_ROUTER_PORT=7447

if [ "${ZENOH_ROUTER_IP}" = "127.0.0.1" ] || [ "${ZENOH_ROUTER_IP}" = "localhost" ]; then
    export ZENOH_CONFIG_OVERRIDE='transport/shared_memory/enabled=true'
else
    export ZENOH_CONFIG_OVERRIDE="transport/shared_memory/enabled=true;mode=\"client\";connect/endpoints=[\"tcp/${ZENOH_ROUTER_IP}:${ZENOH_ROUTER_PORT}\"]"
fi
