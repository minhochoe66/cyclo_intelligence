  <ros2_control is_async="true" name="ffw_f2_sensor" type="system">
    <hardware>
      <plugin>dynamixel_hardware_interface/DynamixelHardware</plugin>
      <param name="port_name">/dev/ttyUSB1</param>
      <param name="baud_rate">4000000</param>
