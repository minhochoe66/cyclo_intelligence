# NVIDIA Isaac GR00T N1.6 Docker Container with Zenoh Communication Support (AMD64)
# This container provides isolated GR00T environment with Zenoh-based communication
# for training (finetuning) and inference commands from orchestrator (ROS2)
#
# Based on official NVIDIA GR00T Dockerfile with Cyclo Intelligence integration
# Build context: cyclo_intelligence/cyclo_brain/policy/groot/
# Usage: docker build -f Dockerfile.amd64 -t robotis/groot-zenoh:amd64 .

# NVIDIA PyTorch base image (same as official GR00T Dockerfile)
ARG BASE_IMAGE=nvcr.io/nvidia/pytorch:25.04-py3
FROM ${BASE_IMAGE}

# GPU architecture build arg (default=use base image PyTorch, blackwell=install nightly cu128)
ARG GPU_ARCH=default

# s6-overlay version (D10-groot — supervises the two-process runtime,
# matches lerobot/Dockerfile.amd64 ARG).
ARG S6_OVERLAY_VERSION=3.2.0.2

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive
ENV NVIDIA_DRIVER_CAPABILITIES=graphics,utility,compute

# Set up locale
RUN apt-get update && apt-get install -y locales \
    && locale-gen en_US en_US.UTF-8 \
    && update-locale LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8 \
    && rm -rf /var/lib/apt/lists/*
ENV LANG=en_US.UTF-8

# Install system dependencies (from official GR00T Dockerfile)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    yasm \
    cmake \
    libtool \
    git \
    pkg-config \
    libass-dev \
    libfreetype6-dev \
    libvorbis-dev \
    autoconf \
    automake \
    texinfo \
    tmux \
    ffmpeg \
    libegl1 \
    && rm -rf /var/lib/apt/lists/*

# Install s6-overlay (supervises main-runtime and engine-process).
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl xz-utils \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL -o /tmp/s6-overlay-noarch.tar.xz \
        https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-noarch.tar.xz \
    && curl -fsSL -o /tmp/s6-overlay-x86_64.tar.xz \
        https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-x86_64.tar.xz \
    && tar -C / -Jxpf /tmp/s6-overlay-noarch.tar.xz \
    && tar -C / -Jxpf /tmp/s6-overlay-x86_64.tar.xz \
    && rm /tmp/s6-overlay-*.tar.xz

# Install uv (fast Python package manager)
RUN pip install --upgrade pip setuptools uv

# Fix constraint file issues (from official GR00T Dockerfile)
# Base image nvcr.io/nvidia/pytorch:25.04-py3 pins versions that conflict with GR00T requirements
RUN sed -i s/dill==0.3.9/dill==0.3.8/g /etc/pip/constraint.txt 2>/dev/null || true \
    && sed -i s/scipy==1.15.2/scipy==1.15.3/g /etc/pip/constraint.txt 2>/dev/null || true \
    && sed -i s/dm-tree==0.1.9/dm-tree==0.1.8/g /etc/pip/constraint.txt 2>/dev/null || true \
    && sed -i s/pyzmq==26.4.0/pyzmq==27.0.1/g /etc/pip/constraint.txt 2>/dev/null || true

# Install GR00T dependencies (from pyproject.toml)
# Core dependencies
RUN pip install --no-cache-dir \
    "albumentations==1.4.18" \
    "av==15.0.0" \
    "diffusers==0.35.1" \
    "dm-tree==0.1.8" \
    "lmdb==1.7.5" \
    "msgpack==1.1.0" \
    "msgpack-numpy==0.4.8" \
    "pandas==2.2.3" \
    "peft==0.17.1" \
    "termcolor==3.2.0" \
    "transformers==4.53.0" \
    "tyro==0.9.17" \
    "click==8.1.8" \
    "datasets==3.6.0" \
    "einops==0.8.1" \
    "gymnasium==1.2.2" \
    "matplotlib==3.10.1" \
    "numpy==1.26.4" \
    "omegaconf==2.3.0" \
    "scipy==1.15.3" \
    "torchcodec==0.4.0" \
    "wandb==0.23.0" \
    "pyzmq==27.0.1" \
    "deepspeed==0.17.6"

# Additional dependencies from official Dockerfile
RUN pip install --no-cache-dir \
    imageio \
    h5py \
    boto3 \
    timm \
    tianshou \
    openai \
    "decord==0.6.0"

# NOTE: pytorch3d is in official Dockerfile but not actually imported in GR00T code
# Skipping it to reduce build time (CUDA kernel compilation takes 20+ minutes)
# If needed later, uncomment below:
# RUN mkdir -p /opt && cd /opt && git clone https://github.com/facebookresearch/pytorch3d.git && cd pytorch3d && pip install .

# Create working directory for GR00T
WORKDIR /gr00t

# Copy GR00T source from submodule
# Build context is cyclo_brain/policy/groot/, so paths are relative to that
COPY Isaac-GR00T/ ./

# Patch pyproject.toml to allow Python 3.12 (base image uses 3.12)
# GR00T officially requires 3.10 but code is compatible with 3.12
RUN sed -i 's/requires-python = "==3.10.\*"/requires-python = ">=3.10"/' pyproject.toml

# Install GR00T package (use pip directly, not uv with --system)
RUN pip install -e . --no-deps && \
    pip install flash-attn --no-build-isolation

# Blackwell (sm_120) support: override PyTorch with nightly cu128 build
RUN if [ "$GPU_ARCH" = "blackwell" ]; then \
      echo "=== Installing PyTorch nightly (cu128) for Blackwell ===" && \
      pip install --no-cache-dir \
        --index-url https://download.pytorch.org/whl/nightly/cu128 \
        torch torchvision torchcodec && \
      pip install --no-cache-dir flash-attn --no-build-isolation --force-reinstall && \
      python -c "import torch; print(f'PyTorch: {torch.__version__}, Arch: {torch.cuda.get_arch_list()}')"; \
    fi

# Zenoh + runtime Python dependencies. zenoh_ros2_sdk / robot_client /
# action_chunk_processing are mounted as volumes (see docker-compose.yml).
# IMPORTANT: eclipse-zenoh version MUST match rmw_zenoh_cpp's bundled zenoh-c version (1.6.x)
# Mismatched versions (e.g., 1.7.x vs 1.6.x) cause service call failures despite discovery working
RUN pip install "eclipse-zenoh>=1.6.0,<1.7.0" rosbags>=0.11.0 GitPython>=3.1.18 json5>=0.9.14 pyyaml \
    && mkdir -p /zenoh_sdk /robot_client_sdk /action_chunk_processing_sdk /orchestrator_config \
                /policy_runtime

# Create application directory for the two-process runtime
WORKDIR /app

# Copy the two-process runtime into the image
COPY runtime/ /app/runtime/
COPY groot_engine/ /app/groot_engine/

# Copy the s6 service definitions
COPY s6-services/ /etc/s6-overlay/s6-rc.d/
RUN chmod +x /etc/s6-overlay/s6-rc.d/main-runtime/run \
             /etc/s6-overlay/s6-rc.d/engine-process/run

# Setup EGL/Vulkan configuration (from official GR00T Dockerfile)
RUN mkdir -p /usr/share/glvnd/egl_vendor.d && \
    cat >/usr/share/glvnd/egl_vendor.d/10_nvidia.json <<'EOF'
{
    "file_format_version" : "1.0.0",
    "ICD" : {
        "library_path" : "libEGL_nvidia.so.0"
    }
}
EOF

RUN mkdir -p /usr/share/vulkan/icd.d && \
    cat >/usr/share/vulkan/icd.d/nvidia_icd.json <<'EOF'
{
    "file_format_version": "1.0.0",
    "ICD": {
        "library_path": "libGLX_nvidia.so.0",
        "api_version": "1.2.140"
    }
}
EOF

# Environment variables for HuggingFace cache (mapped via volume)
ENV HF_HOME=/root/.cache/huggingface
ENV TORCH_HOME=/root/.cache/torch

# Zenoh configuration
ENV ZENOH_ROUTER_IP=127.0.0.1
ENV ZENOH_ROUTER_PORT=7447
ENV ZENOH_SHM_ENABLED=true
ENV ZENOH_SDK_PATH=/zenoh_sdk

# Shared Memory configuration for Zenoh
ENV ZENOH_TRANSPORT_SHM_ENABLED=true

# Runtime SDK paths. Match docker-compose.yml volume mounts.
ENV ROBOT_CLIENT_SDK_PATH=/robot_client_sdk
ENV ACTION_CHUNK_PROCESSING_SDK_PATH=/action_chunk_processing_sdk
ENV ORCHESTRATOR_CONFIG_PATH=/orchestrator_config

# GR00T workspace configuration
ENV GROOT_WORKSPACE=/workspace
ENV POLICY_BACKEND=groot
ENV POLICY_ENGINE_MODULE=groot_engine

# Default working directory
WORKDIR /gr00t

# Healthcheck — both supervised processes must be up.
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD s6-svstat /run/service/main-runtime 2>&1 | grep -q "up" \
     && s6-svstat /run/service/engine-process 2>&1 | grep -q "up" \
     || exit 1

# s6-overlay init — launches both supervised services in parallel.
ENTRYPOINT ["/init"]
