# NVIDIA Isaac GR00T N1.6 Docker Container with Zenoh Communication Support (ARM64/Jetson)
# This container provides isolated GR00T environment with Zenoh-based communication
# for INFERENCE ONLY from orchestrator (ROS2)
#
# Note: Training/finetuning should be done on AMD64 (x86_64) machines
# ARM64/Jetson is optimized for inference deployment only
# Optimized for NVIDIA Jetson Orin series with JetPack 6.x
# Build context: cyclo_intelligence/cyclo_brain/policy/groot/
# Usage: docker build -f Dockerfile.arm64 -t robotis/groot-zenoh:arm64 .

# JetPack 6.x (L4T R36.4) base image for Jetson Orin series
ARG BASE_IMAGE=nvcr.io/nvidia/l4t-jetpack:r36.4.0
FROM ${BASE_IMAGE}

# s6-overlay version (D10-groot — supervises the two-process runtime,
# matches lerobot/Dockerfile.arm64 ARG).
ARG S6_OVERLAY_VERSION=3.2.0.2

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive
ENV NVIDIA_DRIVER_CAPABILITIES=graphics,utility,compute

# Set up locale
RUN apt-get update && apt-get install -y locales \
    && locale-gen en_US en_US.UTF-8 \
    && update-locale LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8 \
    && rm -rf /var/lib/apt/lists/*
ENV LANG=en_US.UTF-8

# Install system dependencies (from official GR00T Dockerfile + Jetson requirements)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    yasm \
    cmake \
    libtool \
    git \
    curl \
    wget \
    ca-certificates \
    pkg-config \
    ninja-build \
    libass-dev \
    libfreetype6-dev \
    libvorbis-dev \
    autoconf \
    automake \
    texinfo \
    tmux \
    ffmpeg \
    libegl1-mesa \
    libegl1-mesa-dev \
    libgl1-mesa-glx \
    libgles2-mesa \
    libglib2.0-0 \
    libusb-1.0-0-dev \
    libopenblas-dev \
    python3-dev \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Install s6-overlay (supervises the two-process runtime — Process A
# inference_server and Process B control_publisher).
RUN curl -fsSL -o /tmp/s6-overlay-noarch.tar.xz \
      https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-noarch.tar.xz \
    && curl -fsSL -o /tmp/s6-overlay-aarch64.tar.xz \
      https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-aarch64.tar.xz \
    && tar -C / -Jxpf /tmp/s6-overlay-noarch.tar.xz \
    && tar -C / -Jxpf /tmp/s6-overlay-aarch64.tar.xz \
    && rm /tmp/s6-overlay-*.tar.xz

# Install uv (fast Python package manager)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
    && mv /root/.local/bin/uv /usr/local/bin/uv

# Create working directory for GR00T
WORKDIR /gr00t

# Create virtual environment using system Python
RUN uv venv /gr00t/.venv --python python3

# Set virtual environment as default
ENV VIRTUAL_ENV=/gr00t/.venv
ENV PATH="/gr00t/.venv/bin:$PATH"

# Install PyTorch for Jetson from Jetson AI Lab pip index
# IMPORTANT: Use ONLY Jetson index (no --extra-index-url) to prevent uv from
# picking CPU wheels from PyPI. Jetson index includes all torch dependencies.
RUN uv pip install torch torchvision \
    --index-url https://pypi.jetson-ai-lab.io/jp6/cu126/+simple

# Install nvidia-cudss-cu12 (required by Jetson PyTorch, not included in l4t-jetpack base)
# --no-deps to avoid re-downloading cublas which is already in the base image
RUN uv pip install --no-deps nvidia-cudss-cu12
ENV LD_LIBRARY_PATH="/gr00t/.venv/lib/python3.10/site-packages/nvidia/cu12/lib:${LD_LIBRARY_PATH}"

# Install GR00T dependencies
# Note: decord==0.6.0 has no ARM64 wheel, built from source below
RUN uv pip install --no-cache \
    imageio \
    h5py \
    boto3 \
    "transformers[torch]==4.51.3" \
    timm \
    peft \
    diffusers \
    wandb \
    tianshou \
    dm-tree \
    openai \
    "albumentations==1.4.18" \
    click \
    datasets \
    einops \
    gymnasium \
    matplotlib \
    "numpy==1.26.4" \
    omegaconf \
    scipy \
    pyzmq \
    tyro \
    lmdb \
    msgpack \
    msgpack-numpy \
    pandas \
    termcolor \
    av

# Build decord from source for ARM64 (no pre-built wheel available)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libavcodec-dev libavfilter-dev libavformat-dev libavutil-dev \
    && rm -rf /var/lib/apt/lists/* \
    && git clone --recursive https://github.com/dmlc/decord /tmp/decord \
    && cd /tmp/decord && mkdir build && cd build \
    && cmake .. -DUSE_CUDA=OFF -DCMAKE_BUILD_TYPE=Release \
    && make -j$(nproc) \
    && cd ../python && pip install . \
    && rm -rf /tmp/decord

# Build flash-attn from source (required by Eagle backbone for inference/training)
# Pre-built wheels from Jetson AI Lab have ABI mismatch with PyTorch 2.9+.
# Default setup.py targets SM 80/90 but Orin is SM 8.7 → "no kernel image" at runtime.
# We download source, patch setup.py to add SM 8.7, and build with only SM 8.7 target.
# MAX_JOBS=4 to avoid OOM on Jetson (build takes ~100 min on Orin)
# flash-attn's setup.py imports both 'packaging' and 'torch' at module
# load time (egg_info), so the Python that runs setup.py must have both.
# 'uv venv' (line 80) does NOT seed pip, so plain 'pip' resolves to the
# *system* pip3 — which has neither torch nor a tractable way to get it.
# Fix: install pip + packaging into the venv (torch is already there from
# step 8), then explicitly invoke the venv's pip with --no-build-isolation
# so egg_info runs under the venv Python and finds everything it needs.
RUN uv pip install pip packaging \
    && /gr00t/.venv/bin/pip download flash-attn --no-binary :all: --no-deps --no-build-isolation -d /tmp/flash-attn-src \
    && mkdir -p /tmp/flash-attn-build \
    && tar xzf /tmp/flash-attn-src/flash_attn-*.tar.gz -C /tmp/flash-attn-build --strip-components=1 \
    && cd /tmp/flash-attn-build \
    && sed -i 's/return os.getenv("FLASH_ATTN_CUDA_ARCHS", "80;90;100;120")/return os.getenv("FLASH_ATTN_CUDA_ARCHS", "87")/' setup.py \
    && sed -i 's/if "80" in cuda_archs():/if set(cuda_archs()) \& {"80", "87"}:/' setup.py \
    && sed -i '/arch=compute_80,code=sm_80/a\\        cc_flag.append("-gencode")\n        cc_flag.append("arch=compute_87,code=sm_87")' setup.py \
    && MAX_JOBS=4 uv pip install . --no-build-isolation \
    && rm -rf /tmp/flash-attn-src /tmp/flash-attn-build

# Install triton (required by flash_attn rotary ops)
RUN uv pip install triton --index-url https://pypi.jetson-ai-lab.io/jp6/cu126/+simple

# Note: deepspeed has limited ARM64 support
# Training may need to use alternative optimizers
# RUN uv pip install deepspeed

# Note: torchcodec may not be available for ARM64
# Video loading will fall back to other backends
# RUN uv pip install torchcodec==0.4.0

# Copy GR00T source from submodule
# Build context is cyclo_brain/policy/groot/, so paths are relative to that
COPY Isaac-GR00T/ ./

# Patch pyproject.toml to relax Python version requirement
RUN sed -i 's/requires-python = "==3.10.*"/requires-python = ">=3.10"/' pyproject.toml

# TensorRT DiT acceleration (1.73x speedup on Orin)
# System TRT libs (10.3.0) are at /usr/lib/python3.10/dist-packages/ but not
# visible inside the venv. Symlink them in instead of pip-installing a mismatched version.
RUN for pkg in tensorrt tensorrt-10.3.0.dist-info \
               tensorrt_dispatch tensorrt_dispatch-10.3.0.dist-info \
               tensorrt_lean tensorrt_lean-10.3.0.dist-info; do \
        ln -sf /usr/lib/python3.10/dist-packages/$pkg \
               /gr00t/.venv/lib/python3.10/site-packages/$pkg; \
    done \
    && uv pip install --no-cache "onnx>=1.20.0" onnxscript

# Install GR00T package in editable mode (without strict dependencies)
RUN uv pip install -e . --no-deps

# Zenoh + runtime Python dependencies. zenoh_ros2_sdk / robot_client /
# post_processing are mounted as volumes (see docker-compose.yml).
# IMPORTANT: eclipse-zenoh version MUST match rmw_zenoh_cpp's bundled zenoh-c version (1.6.x)
# Mismatched versions (e.g., 1.7.x vs 1.6.x) cause service call failures despite discovery working
RUN uv pip install "eclipse-zenoh>=1.6.0,<1.7.0" rosbags>=0.11.0 GitPython>=3.1.18 json5>=0.9.14 pyyaml \
    && mkdir -p /zenoh_sdk /robot_client_sdk /post_processing_sdk /orchestrator_config

# Create application directory for the two-process runtime
WORKDIR /app

# Copy the two-process runtime into the image
COPY runtime/ /app/runtime/

# Copy the s6 service definitions
COPY s6-services/ /etc/s6-overlay/s6-rc.d/
RUN chmod +x /etc/s6-overlay/s6-rc.d/inference-server/run \
             /etc/s6-overlay/s6-rc.d/control-publisher/run

# Setup EGL configuration for Jetson
RUN mkdir -p /usr/share/glvnd/egl_vendor.d && \
    cat >/usr/share/glvnd/egl_vendor.d/10_nvidia.json <<'EOF'
{
    "file_format_version" : "1.0.0",
    "ICD" : {
        "library_path" : "libEGL_nvidia.so.0"
    }
}
EOF

# Environment variables for HuggingFace cache (mapped via volume)
ENV HF_HOME=/root/.cache/huggingface
ENV TORCH_HOME=/root/.cache/torch

# Zenoh configuration
ENV ZENOH_ROUTER_IP=127.0.0.1
ENV ZENOH_ROUTER_PORT=7447
ENV ZENOH_SHM_ENABLED=true
ENV ZENOH_SDK_PATH=/zenoh_sdk

# Shared Memory configuration for Zenoh
ENV ZENOH_TRANSPORT_SHM_ENABLED=true

# Runtime SDK paths (consumed by runtime/inference_server.py and
# runtime/control_publisher.py). Match docker-compose.yml volume mounts.
ENV ROBOT_CLIENT_SDK_PATH=/robot_client_sdk
ENV POST_PROCESSING_SDK_PATH=/post_processing_sdk
ENV ORCHESTRATOR_CONFIG_PATH=/orchestrator_config

# GR00T workspace configuration
ENV GROOT_WORKSPACE=/workspace

# LeRobot workspace (for dataset compatibility)
ENV LEROBOT_WORKSPACE=/workspace

# Default working directory
WORKDIR /gr00t

# Healthcheck — both supervised processes must be up.
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD s6-svstat /run/service/inference-server 2>&1 | grep -q "up" \
     && s6-svstat /run/service/control-publisher 2>&1 | grep -q "up" \
     || exit 1

# s6-overlay init — launches both supervised services in parallel.
ENTRYPOINT ["/init"]
