# Build context hygiene — keep the LeRobot image build deterministic
# and prevent accidental host-side scratch dirs from bleeding into the
# image. Runtime data lives on the compose-mounted ./workspace
# (host: docker/workspace/), shared with cyclo_intelligence and
# the other policy containers — not under this build context.

workspace/
.git/
__pycache__/
*.pyc
*.pyo
.venv/
.cache/
*.log

# Submodule build artifacts
lerobot/.venv/
lerobot/build/
lerobot/dist/
lerobot/*.egg-info/
