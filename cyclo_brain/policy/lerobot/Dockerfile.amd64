# LeRobot Docker Container with Zenoh Communication Support (AMD64)
#
# Two-process policy runtime: s6-overlay supervises main-runtime
# (external service + robot-facing control loop) and engine-process
# (policy deps + RobotClient sensor reads + inference).
#
# The runtime + s6 services are policy-agnostic and live under
# cyclo_brain/policy/common/. This image only ships the LeRobot deps
# and bakes the common s6 unit files; the actual Python source for
# Runtime packages and lerobot_engine are bind-mounted at runtime so the
# container can be iterated without rebuilds.
#
# Build context: cyclo_brain/policy/        (NOTE: parent of lerobot/)
# Usage:         docker build -f lerobot/Dockerfile.amd64 \
#                  -t robotis/lerobot-zenoh:amd64 .

# NVIDIA PyTorch base image (Python 3.12 — required by upstream lerobot
# pyproject.toml ``requires-python = ">=3.12"``).
ARG BASE_IMAGE=nvcr.io/nvidia/pytorch:24.12-py3
FROM ${BASE_IMAGE}

# GPU architecture build arg (default=use base image PyTorch, blackwell=install nightly cu128)
ARG GPU_ARCH=default

# s6-overlay version (supervises the two processes)
ARG S6_OVERLAY_VERSION=3.2.0.2

ENV DEBIAN_FRONTEND=noninteractive

# Locale
RUN apt-get update && apt-get install -y locales \
    && locale-gen en_US en_US.UTF-8 \
    && update-locale LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8 \
    && rm -rf /var/lib/apt/lists/*
ENV LANG=en_US.UTF-8

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake \
    pkg-config \
    ninja-build \
    libglib2.0-0 \
    libegl-mesa0 \
    libegl1-mesa-dev \
    libgl1-mesa-dri \
    libgles2 \
    ffmpeg \
    libusb-1.0-0-dev \
    speech-dispatcher \
    libgeos-dev \
    portaudio19-dev \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

# s6-overlay (supervises the two runtime processes)
RUN curl -fsSL -o /tmp/s6-overlay-noarch.tar.xz \
      https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-noarch.tar.xz \
    && curl -fsSL -o /tmp/s6-overlay-x86_64.tar.xz \
      https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-x86_64.tar.xz \
    && tar -C / -Jxpf /tmp/s6-overlay-noarch.tar.xz \
    && tar -C / -Jxpf /tmp/s6-overlay-x86_64.tar.xz \
    && rm /tmp/s6-overlay-*.tar.xz

# uv (fast Python package manager)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
    && mv /root/.local/bin/uv /usr/local/bin/uv

WORKDIR /lerobot

# Virtual env on top of the base image's Python 3.12
RUN uv venv /lerobot/.venv --python python3
ENV VIRTUAL_ENV=/lerobot/.venv
ENV PATH="/lerobot/.venv/bin:$PATH"

# Copy LeRobot source (paths now relative to cyclo_brain/policy/ build context)
COPY lerobot/lerobot/setup.py lerobot/lerobot/pyproject.toml lerobot/lerobot/README.md lerobot/lerobot/MANIFEST.in ./
COPY lerobot/lerobot/src/ ./src/

# Install training/inference + VLA extras. Removed: dynamixel/gamepad/
# hopejr/lekiwi/reachy2/kinematics (hardware), dev/test/video_benchmark
# (development), aloha/pusht/phone/libero/metaworld/sarm (simulation).
RUN uv pip install --no-cache ".[smolvla,xvla,hilserl,async,peft]"

# Blackwell (sm_120) support: override PyTorch with nightly cu128 build
RUN if [ "$GPU_ARCH" = "blackwell" ]; then \
      echo "=== Installing PyTorch nightly (cu128) for Blackwell ===" && \
      uv pip install --no-cache \
        --index-url https://download.pytorch.org/whl/nightly/cu128 \
        torch torchvision torchcodec && \
      python -c "import torch; print(f'PyTorch: {torch.__version__}, Arch: {torch.cuda.get_arch_list()}')"; \
    fi

# Copy the rest of LeRobot (configs, tests, etc.)
COPY lerobot/lerobot/ ./

# Zenoh + runtime Python deps. zenoh_ros2_sdk / robot_client /
# action_chunk_processing come in via bind-mount (see docker-compose.yml).
# IMPORTANT: eclipse-zenoh version MUST match rmw_zenoh_cpp's bundled
# zenoh-c version (1.6.x). Mismatched versions cause service call
# failures despite discovery working.
RUN uv pip install "eclipse-zenoh>=1.6.0,<1.7.0" rosbags>=0.11.0 GitPython>=3.1.18 json5>=0.9.14 pyyaml \
    && mkdir -p /zenoh_sdk /robot_client_sdk /action_chunk_processing_sdk /orchestrator_config \
                /policy_runtime /app

# s6 unit files come from cyclo_brain/policy/common/. Generic across all
# policy backends — never edited per-policy.
COPY common/s6-services/ /etc/s6-overlay/s6-rc.d/
RUN chmod +x /etc/s6-overlay/s6-rc.d/main-runtime/run \
             /etc/s6-overlay/s6-rc.d/engine-process/run

# HuggingFace cache (bind-mounted from compose so weights survive rebuild).
ENV HF_HOME=/root/.cache/huggingface
ENV HF_LEROBOT_HOME=/root/.cache/huggingface/lerobot
ENV TORCH_HOME=/root/.cache/torch

# Zenoh
ENV ZENOH_ROUTER_IP=127.0.0.1
ENV ZENOH_ROUTER_PORT=7447
ENV ZENOH_SHM_ENABLED=true
ENV ZENOH_SDK_PATH=/zenoh_sdk
ENV ZENOH_TRANSPORT_SHM_ENABLED=true

# Bind-mount roots consumed by /policy_runtime/main_runtime and
# /policy_runtime/engine_process. Defaults match the compose
# volume mounts; override if layout changes.
ENV ROBOT_CLIENT_SDK_PATH=/robot_client_sdk
ENV ACTION_CHUNK_PROCESSING_SDK_PATH=/action_chunk_processing_sdk
ENV ORCHESTRATOR_CONFIG_PATH=/orchestrator_config

# Common runtime dispatch. POLICY_BACKEND drives service names, and
# POLICY_ENGINE_MODULE points at the backend engine package.
ENV POLICY_BACKEND=lerobot
ENV POLICY_ENGINE_MODULE=lerobot_engine

WORKDIR /lerobot

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD s6-svstat /run/service/main-runtime 2>&1 | grep -q "up" \
     && s6-svstat /run/service/engine-process 2>&1 | grep -q "up" \
     || exit 1

# s6-overlay init — launches both supervised services in parallel
ENTRYPOINT ["/init"]
