<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="DemoSequence">
      <SendCommand name="LoadModel"
        command="LOAD"
        model="groot:n17"
        policy_path="/policy_checkpoints/groot/test"
        task_instruction="Place the paper cups in to the basket."
        inference_hz="15"
        control_hz="100"
        chunk_align_window_s="0.3"/>
      <JointControl name="InitPosition"
        enable_head="true"
        head_positions="0.5, 0.0"
        enable_arms="true"
        left_positions="0.75, 0.0, 0.0, -2.3, 0.0, 0.0, 0.0, 0.0"
        right_positions="0.75, 0.0, 0.0, -2.3, 0.0, 0.0, 0.0, 0.0"
        enable_lift="true"
        lift_position="-0.1"
        duration="2.0"/>
      <Rotate name="TurnLeft" angle_deg="90.0"/>
      <Loop name="RepeatPick&amp;Place" max_iterations="3">
        <SendCommand name="ResumeInference" command="RESUME"/>
        <Wait name="HoldInference" duration="3.0"/>
        <SendCommand name="StopInference" command="STOP"/>
        <JointControl name="InitArms"
          enable_arms="true"
          left_positions="0.75, 0.0, 0.0, -2.3, 0.0, 0.0, 0.0, 0.0"
          right_positions="0.75, 0.0, 0.0, -2.3, 0.0, 0.0, 0.0, 0.0"
          duration="5.0"/>
      </Loop>
      <SendCommand name="UnloadModel" command="CLEAR"/>
    </Sequence>
  </BehaviorTree>
</root>
